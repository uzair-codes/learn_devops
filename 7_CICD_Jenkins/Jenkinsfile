// In a Declarative Pipeline, the structure must follow this order:
    // pipeline
    // ├─ agent
    // ├─ tools
    // ├─ stages
    // │   ├─ stage
    // │   │   ├─ steps
    // │   │   └─ post (optional, but must be inside the stage)
    // └─ post (pipeline-level)

pipeline {
    agent any
    
    // Install the Maven version configured as "jenkins-maven" and add it to the path.
    tools {
        maven 'jenkins-maven'
    }

    stages {
        stage('Build') {
            steps {
                // Get some code from a GitHub repository
                git 'https://github.com/jenkins-docs/simple-java-maven-app.git'
               
                // Run Maven on a Unix agent.
                sh 'mvn -B -Dmaven.test.failure.ignore=true clean package'
                // Command Breakdown
                // mvn: The entry point for the Apache Maven build tool.
                // -B : (or --batch-mode): Runs Maven in non-interactive mode. 
                //      This prevents it from asking for user input and removes "noise" from the logs (like download progress bars for dependencies). 
                //      It’s the standard for CI/CD pipelines (Jenkins, GitHub Actions, etc.)
                // -Dmaven.test.failure.ignore=true: This flag instructs the Maven Surefire Plugin to continue the build process even if there are test failures.
                //                                   Note: Unlike -DskipTests, the tests will still run, but their failure won't stop the build.
                // -DskipTests: Tells Maven not to run the tests at all. 
                //              This significantly speeds up the build process because it skips both execution and the generation of test reports.
                // clean: Deletes the target directory, removing all files generated by previous builds to ensure a "fresh" start.
                // package: Executes all phases of the default lifecycle up to packaging. This includes compiling source code, processing resources, and running unit tests before creating the final artifact (e.g., a .jar or .war file) in the target folder. 

                // To run Maven on a Windows agent, use
                // bat "mvn -Dmaven.test.failure.ignore=true clean package"            
            }
        }
        stage('Test'){
            steps {
                sh 'mvn test'
            }
            post {
                // If Maven was able to run the tests, even if some of the test
                // failed, record the test results and archive the jar file.
                success {
                    junit '**/target/surefire-reports/TEST-*.xml'
                    // archiveArtifacts 'target/*.jar'
                }
                //  Always record the test results
                // always {
                //     junit 'target/surefire-reports/*.xml'
                // }
            }         
        } 
        stage('Approval') {
            input 'Approve Deployment to Production'
        }
        stage('Deploy') {
            steps{
                sh 'echo Deployed'
            }
        }
    }
    //  Post Deployment Actions
    post {
        failure {
            echo 'Failure'
            mail to: 'gojosalar@gmail.com',
                subject: "FAILED: ${env.JOB_NAME} - Build #${env.BUILD_NUMBER}",
                body: "Job '${env.JOB_NAME}' - (${env.BUILD_URL}) Failed"
        }
        success {
            echo 'Build and Test Stages Succssful!'
            archiveArtifacts artifacts: '**/target/*.jar', onlyIfSuccessful: true
        }
    }
}